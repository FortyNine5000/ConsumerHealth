---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" noIndex={true}>
  <div class="max-w-xl mx-auto px-4 py-24 text-center">
    <div class="text-6xl font-bold text-compass-navy mb-4">404</div>
    <h1 class="text-xl font-semibold text-gray-700 mb-2">Page not found</h1>
    <p class="text-gray-400 mb-8">That page doesn't exist or may have moved.</p>
    <a
      href="/"
      class="inline-flex items-center gap-2 bg-compass-navy text-white px-5 py-2.5 rounded-lg text-sm font-medium hover:bg-compass-navy/90 transition-colors"
    >
      ← Back to dashboard
    </a>
  </div>
</BaseLayout>
