# ── Data Source API Keys ────────────────────────────────────────────────────
# FRED (Federal Reserve Bank of St. Louis)
# Register at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Bureau of Labor Statistics
# Register at: https://www.bls.gov/developers/api_signature_v2.htm
BLS_API_KEY=

# Bureau of Economic Analysis
# Register at: https://apps.bea.gov/api/signup/
BEA_API_KEY=

# U.S. Census Bureau
# Register at: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# Energy Information Administration
# Register at: https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# ── Database ────────────────────────────────────────────────────────────────
# Turso (libSQL) — free tier at https://turso.tech
# Format: libsql://your-db-name.turso.io
TURSO_DATABASE_URL=libsql://your-db-name.turso.io

# Turso auth token (from turso auth token command or dashboard)
TURSO_AUTH_TOKEN=

# ── AI ──────────────────────────────────────────────────────────────────────
# Anthropic API (for quote classification and monthly summaries)
# Register at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Deployment ──────────────────────────────────────────────────────────────
# Cloudflare Pages deploy hook URL (triggers a new build/deploy)
# Find in: Cloudflare Dashboard → Pages → your project → Settings → Builds & deployments
CLOUDFLARE_DEPLOY_HOOK_URL=

# ── SEC EDGAR ───────────────────────────────────────────────────────────────
# SEC requires a descriptive User-Agent string for API access
# Format: "Name/Version (contact@email.com)"
SEC_USER_AGENT=ConsumerCompass/1.0 (admin@example.com)

# ── Newsletter ──────────────────────────────────────────────────────────────
BEEHIIV_API_KEY=
