---
import BaseLayout from '../../layouts/BaseLayout.astro';
import IndicatorChart from '../../components/IndicatorChart.astro';
import { getAllIndicators, getIndicatorBySlug, getIndicatorHistory } from '../../lib/db';
import { scoreToBand, formatDate, SUBSCORE_LABELS } from '../../lib/scoring';

export async function getStaticPaths() {
  try {
    const indicators = await getAllIndicators();
    return indicators.map((ind) => ({ params: { slug: ind.slug } }));
  } catch {
    return [];
  }
}

const { slug } = Astro.params;

let indicator = null;
let history = [];

try {
  [indicator, history] = await Promise.all([
    getIndicatorBySlug(slug!),
    getIndicatorHistory(slug!),
  ]);
} catch (e) {}

if (!indicator) {
  return Astro.redirect('/indicators');
}

const latestHistory = history[history.length - 1];
const latestScore = latestHistory?.smoothed_score ?? latestHistory?.score ?? null;
const latestValue = latestHistory?.raw_value ?? null;
const latestDate = latestHistory?.score_date ?? null;
const band = latestScore != null ? scoreToBand(latestScore) : null;

const directionLabel =
  indicator.scoring_type === 'proximity_2pct' ? 'Closer to 2% = better' :
  indicator.higher_is_better === 1 ? 'Higher is better' :
  indicator.higher_is_better === 0 ? 'Lower is better' :
  'Context only';

const subscore_label = SUBSCORE_LABELS[indicator.subscore] ?? indicator.subscore;
---

<BaseLayout
  title={indicator.label}
  description={indicator.description ?? `${indicator.label} — consumer health indicator tracked by The Consumer Compass.`}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-400 mb-6 flex items-center gap-2">
      <a href="/indicators" class="hover:text-compass-teal transition-colors">Indicators</a>
      <span>›</span>
      <a href={`/subscores/${indicator.subscore}`} class="hover:text-compass-teal transition-colors">{subscore_label}</a>
      <span>›</span>
      <span class="text-gray-600">{indicator.label}</span>
    </nav>

    <!-- Header -->
    <div class="flex items-start justify-between gap-6 mb-8">
      <div>
        <h1 class="text-2xl sm:text-3xl font-bold text-compass-navy">{indicator.label}</h1>
        <div class="flex flex-wrap items-center gap-3 mt-2 text-sm text-gray-500">
          <span class="font-mono bg-gray-100 px-2 py-0.5 rounded text-xs">{indicator.series_id}</span>
          <span>{indicator.frequency}</span>
          {indicator.source_name && (
            indicator.source_url ? (
              <a href={indicator.source_url} target="_blank" rel="noopener" class="text-compass-teal hover:underline">
                {indicator.source_name}
              </a>
            ) : (
              <span>{indicator.source_name}</span>
            )
          )}
        </div>
        {indicator.description && (
          <p class="mt-3 text-gray-600 text-sm leading-relaxed max-w-2xl">{indicator.description}</p>
        )}
      </div>

      {band && latestScore != null && (
        <div class="text-right shrink-0">
          <div class="text-4xl font-bold tabular-nums" style={`color: ${band.color}`}>
            {latestScore.toFixed(0)}
          </div>
          <div class="text-sm font-medium mt-0.5" style={`color: ${band.color}`}>{band.label}</div>
          {latestDate && (
            <div class="text-xs text-gray-400 mt-1">{formatDate(latestDate)}</div>
          )}
        </div>
      )}
    </div>

    <!-- Stats row -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
      <div class="bg-white rounded-xl border border-gray-100 p-4 shadow-sm">
        <div class="text-xs text-gray-400 uppercase tracking-wide mb-1">Current Score</div>
        <div class="text-xl font-bold" style={band ? `color: ${band.color}` : ''}>
          {latestScore != null ? latestScore.toFixed(1) : '—'}
        </div>
      </div>
      <div class="bg-white rounded-xl border border-gray-100 p-4 shadow-sm">
        <div class="text-xs text-gray-400 uppercase tracking-wide mb-1">Current Value</div>
        <div class="text-xl font-bold text-compass-navy font-mono">
          {latestValue != null ? latestValue.toFixed(2) : '—'}
          {indicator.unit && <span class="text-sm text-gray-400 ml-1">{indicator.unit}</span>}
        </div>
      </div>
      <div class="bg-white rounded-xl border border-gray-100 p-4 shadow-sm">
        <div class="text-xs text-gray-400 uppercase tracking-wide mb-1">Direction</div>
        <div class="text-sm font-medium text-gray-700">{directionLabel}</div>
      </div>
      <div class="bg-white rounded-xl border border-gray-100 p-4 shadow-sm">
        <div class="text-xs text-gray-400 uppercase tracking-wide mb-1">Sub-Score</div>
        <a href={`/subscores/${indicator.subscore}`} class="text-sm font-medium text-compass-teal hover:underline">
          {subscore_label}
        </a>
      </div>
    </div>

    <!-- Chart -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 mb-8">
      <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-4">Score History (0–100)</h2>
      {history.length > 0 ? (
        <IndicatorChart indicator={indicator} history={history} showRawValue={true} />
      ) : (
        <div class="h-48 flex items-center justify-center text-gray-400 text-sm">
          No history available yet.
        </div>
      )}
    </div>

    <!-- Scoring notes -->
    <div class="bg-gray-50 rounded-xl border border-gray-200 p-5 text-sm text-gray-600 leading-relaxed">
      <h3 class="font-semibold text-gray-700 mb-2">Scoring Notes</h3>
      <ul class="list-disc list-inside space-y-1">
        <li>Score uses expanding-window percentile rank (no look-ahead bias).</li>
        {indicator.scoring_type === 'proximity_2pct' && (
          <li>CPI special case: scored by <strong>proximity to 2% target</strong> — |YoY − 2%| is ranked; lower distance = higher score.</li>
        )}
        {indicator.scoring_type === 'context_only' && (
          <li>Context-only: this indicator is charted for context but <strong>not included in sub-score calculations</strong>.</li>
        )}
        {indicator.frequency === 'quarterly' && (
          <li>Quarterly data is forward-filled up to 3 months into the monthly sub-score timeline.</li>
        )}
        <li>Gray shaded bars on the chart mark NBER-defined U.S. recessions.</li>
      </ul>
      <p class="mt-3 text-xs text-gray-400">
        <a href="/methodology" class="text-compass-teal hover:underline">Full methodology →</a>
      </p>
    </div>
  </div>
</BaseLayout>
