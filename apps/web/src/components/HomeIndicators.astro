---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  getAllIndicators,
  getHeadlineHistory,
  getLatestHeadlineScore,
  getLatestSubScores,
} from '../lib/db';
import {
  scoreToBand,
  SUBSCORE_DESCRIPTIONS,
  SUBSCORE_LABELS,
} from '../lib/scoring';

let indicators = [];
let headline = null;
let headlineHistory = [];
let latestSubscores = [];

try { indicators = await getAllIndicators(); } catch (e) {}
try { headline = await getLatestHeadlineScore(); } catch (e) {}
try { headlineHistory = await getHeadlineHistory(); } catch (e) {}
try { latestSubscores = await getLatestSubScores(); } catch (e) {}

const scored = indicators.filter((i) => i.is_scored === 1);
const subscoreOrder = [
  'big_ticket_affordability',
  'credit_stress',
  'household_balance_sheet',
  'inflation_affordability',
  'labor_income',
  'sentiment_expectations',
  'spending_demand',
];

const subscoreWeights: Record<string, number> = {
  labor_income: 0.20,
  household_balance_sheet: 0.15,
  credit_stress: 0.20,
  spending_demand: 0.15,
  sentiment_expectations: 0.10,
  inflation_affordability: 0.10,
  big_ticket_affordability: 0.10,
};

const subscoreFullLabels: Record<string, string> = {
  labor_income: 'Labor & Income',
  household_balance_sheet: 'Household Balance Sheet',
  credit_stress: 'Credit Stress',
  spending_demand: 'Spending & Demand',
  sentiment_expectations: 'Sentiment & Expectations',
  inflation_affordability: 'Inflation Affordability',
  big_ticket_affordability: 'Big-Ticket Affordability',
};

const statusColors: Record<string, string> = {
  'Very Strong': '#1f3df5',
  Healthy: '#345544',
  Mixed: '#7a6a44',
  Weakening: '#a04a2a',
  Stressed: '#8a2a2a',
  Crisis: '#5c0c12',
  Tracked: '#7a8290',
};

function statusFor(score: number | null) {
  if (score == null) return { label: 'Tracked', color: statusColors.Tracked };
  const band = scoreToBand(score);
  return { label: band.label, color: statusColors[band.label] ?? band.color };
}

function average(values: Array<number | null>) {
  const valid = values.filter((v): v is number => v != null && Number.isFinite(v));
  if (valid.length === 0) return null;
  return valid.reduce((sum, v) => sum + v, 0) / valid.length;
}

function shortUnit(unit: string | null) {
  const u = (unit ?? '').toLowerCase();
  if (u.includes('dollars per gallon')) return '$/gal';
  if (u.includes('dollars')) return '$';
  if (u.includes('thousands')) return 'k';
  if (u.includes('percent')) return '%';
  if (u.includes('ratio')) return 'x';
  if (u.includes('index')) return 'idx';
  if (u.includes('hours')) return 'hrs';
  return unit ?? '';
}

function decimalsFor(unit: string | null, value: number | null) {
  const u = (unit ?? '').toLowerCase();
  if (value != null && Math.abs(value) >= 1000) return 0;
  if (u.includes('thousands')) return 0;
  if (u.includes('index') || u.includes('hours')) return 1;
  return 2;
}

function formatValue(value: number | null, unit: string | null) {
  if (value == null || !Number.isFinite(value)) return '-';
  const decimals = decimalsFor(unit, value);
  return value.toLocaleString('en-US', {
    minimumFractionDigits: decimals,
    maximumFractionDigits: decimals,
  });
}

function formatDelta(value: number | null, unit: string | null) {
  if (value == null || !Number.isFinite(value)) return '-';
  const decimals = decimalsFor(unit, value);
  const sign = value > 0 ? '+' : value < 0 ? '-' : '+/-';
  return `${sign}${Math.abs(value).toLocaleString('en-US', {
    minimumFractionDigits: decimals,
    maximumFractionDigits: decimals,
  })}`;
}

function deltaLabel(frequency: string) {
  if (frequency === 'weekly') return 'wk/wk';
  if (frequency === 'quarterly') return 'qtr/qtr';
  if (frequency === 'daily') return 'day/day';
  return 'mo/mo';
}

function formatFullDate(dateStr: string | null) {
  if (!dateStr) return 'No data';
  const d = new Date(`${dateStr}T00:00:00Z`);
  return d.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
    timeZone: 'UTC',
  });
}

function buildSpark(values: number[], width = 220, height = 56, pad = 3, fixedMin?: number, fixedMax?: number) {
  if (values.length < 2) return null;
  const min = fixedMin ?? Math.min(...values);
  const max = fixedMax ?? Math.max(...values);
  const range = max - min || 1;
  const points = values.map((value, index) => {
    const x = pad + (index / (values.length - 1)) * (width - pad * 2);
    const y = pad + (1 - (value - min) / range) * (height - pad * 2);
    return [x, y];
  });
  const d = points
    .map(([x, y], index) => `${index === 0 ? 'M' : 'L'}${x.toFixed(2)} ${y.toFixed(2)}`)
    .join(' ');
  const area = `${d} L${(width - pad).toFixed(2)} ${(height - pad).toFixed(2)} L${pad} ${(height - pad).toFixed(2)} Z`;
  const last = points[points.length - 1];
  return { d, area, last, min, max };
}

const latestSubscoreBySlug = new Map(latestSubscores.map((s) => [s.slug, s]));

const cards = scored.map((indicator) => {
  const sparkline = indicator.sparkline.length > 1
    ? indicator.sparkline
    : indicator.score_sparkline;
  const value = indicator.latest_value;
  const delta = indicator.sparkline.length > 1
    ? indicator.sparkline[indicator.sparkline.length - 1] - indicator.sparkline[indicator.sparkline.length - 2]
    : null;
  const score = indicator.latest_score;
  const status = statusFor(score);
  const spark = buildSpark(sparkline);
  return {
    slug: indicator.slug,
    subscore: indicator.subscore,
    subscoreLabel: subscoreFullLabels[indicator.subscore] ?? SUBSCORE_LABELS[indicator.subscore] ?? indicator.subscore,
    label: indicator.label,
    code: indicator.series_id,
    frequency: indicator.frequency,
    scoringType: indicator.scoring_type,
    score,
    scoreText: score == null ? '-' : String(Math.round(score)),
    status,
    value,
    valueText: formatValue(value, indicator.unit),
    unit: shortUnit(indicator.unit),
    unitLong: indicator.unit ?? '',
    delta,
    deltaText: formatDelta(delta, indicator.unit),
    deltaLabel: deltaLabel(indicator.frequency),
    deltaGood: delta == null ? null : indicator.higher_is_better === 0 ? delta < 0 : delta > 0,
    sourceName: indicator.source_name ?? 'Source',
    sourceUrl: indicator.source_url,
    description: indicator.description,
    latestDate: formatFullDate(indicator.latest_date),
    sparkline,
    scoreSparkline: indicator.score_sparkline,
    spark,
  };
});

const groups: Array<{
  slug: string;
  label: string;
  shortLabel: string;
  description: string;
  weight: number;
  score: number | null;
  scoreText: string;
  status: { label: string; color: string };
  cards: typeof cards;
}> = [];

for (const slug of subscoreOrder) {
  const groupCards = cards.filter((card) => card.subscore === slug);
  if (groupCards.length === 0) continue;
  const latest = latestSubscoreBySlug.get(slug);
  const score = latest?.score ?? average(groupCards.map((card) => card.score));
  const status = statusFor(score);
  groups.push({
    slug,
    label: subscoreFullLabels[slug] ?? SUBSCORE_LABELS[slug] ?? slug,
    shortLabel: SUBSCORE_LABELS[slug] ?? slug,
    description: SUBSCORE_DESCRIPTIONS[slug] ?? '',
    weight: subscoreWeights[slug] ?? 0,
    score,
    scoreText: score == null ? '-' : String(Math.round(score)),
    status,
    cards: groupCards,
  });
}

const headlineScore = headline?.score ?? null;
const headlineStatus = statusFor(headlineScore);
const headlineScores = headlineHistory.slice(-60).map((row) => row.score);
const headlineSpark = buildSpark(headlineScores, 460, 130, 6, 0, 100);
const headlineScoreText = headlineScore == null ? '-' : String(Math.round(headlineScore));
const updatedLabel = formatFullDate(headline?.score_date ?? null);
---

<BaseLayout
  title="The Consumer Compass"
  description="A free public dashboard tracking U.S. consumer financial health from public government data."
>
  <div class="indicators-page">
    <section class="indicators-hero">
      <div class="hero-copy">
        <h1>How the U.S. consumer is holding up.</h1>
        <p>
          {scored.length} series across {groups.length} sub-scores, normalized to each indicator's
          own expanding historical distribution and aggregated into a composite read on household
          financial health.
        </p>
        <div class="hero-updated">Updated {updatedLabel}</div>
      </div>

      <div class="composite-card">
        <div class="composite-top">
          <div>
            <div class="eyebrow">Composite Score</div>
            <div class="composite-score">{headlineScoreText}</div>
            <div class="status-line" style={`--status: ${headlineStatus.color}`}>
              <span></span>
              {headlineStatus.label}
            </div>
          </div>
          <div class="composite-deltas">
            <div>
              <span>vs prior</span>
              <strong class={headline?.delta_1m != null && headline.delta_1m < 0 ? 'delta-bad' : ''}>{formatDelta(headline?.delta_1m ?? null, null)}</strong>
            </div>
            <div>
              <span>vs year</span>
              <strong class={headline?.delta_12m != null && headline.delta_12m < 0 ? 'delta-bad' : ''}>{formatDelta(headline?.delta_12m ?? null, null)}</strong>
            </div>
          </div>
        </div>

        {headlineSpark ? (
          <div class="composite-history">
            <div class="history-head">
              <span>Composite · 5-year history</span>
              <span>0-100 scale</span>
            </div>
            <svg viewBox="0 0 460 130" role="img" aria-label="Composite score history">
              <defs>
                <linearGradient id="headline-gradient" x1="0" x2="0" y1="0" y2="1">
                  <stop offset="0%" stop-color={headlineStatus.color} stop-opacity="0.22" />
                  <stop offset="100%" stop-color={headlineStatus.color} stop-opacity="0" />
                </linearGradient>
              </defs>
              {[25, 50, 75].map((tick) => {
                const y = 6 + (1 - tick / 100) * 118;
                return (
                  <g>
                    <line x1="30" x2="430" y1={y} y2={y} stroke="#e6e3da" stroke-dasharray={tick === 50 ? '0' : '2 4'} />
                    <text x="22" y={y + 3} text-anchor="end">{tick}</text>
                  </g>
                );
              })}
              <path d={headlineSpark.area} fill="url(#headline-gradient)" />
              <path d={headlineSpark.d} fill="none" stroke={headlineStatus.color} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
              <circle cx={headlineSpark.last[0]} cy={headlineSpark.last[1]} r="4" fill="#ffffff" stroke={headlineStatus.color} stroke-width="2" />
            </svg>
          </div>
        ) : (
          <div class="composite-empty">Composite history will appear after ingestion runs.</div>
        )}

        {groups.length > 0 && (
          <div class="subscore-mini">
            {groups.map((group) => (
              <button type="button" data-filter={group.slug} title={group.label}>
                <span class="mini-bar-track">
                  <span
                    class="mini-bar"
                    style={`height: ${Math.max(8, group.score ?? 0)}%; background: ${group.status.color}`}
                  />
                </span>
                <span class="mini-label">{group.shortLabel}</span>
                <strong>{group.scoreText}</strong>
              </button>
            ))}
          </div>
        )}
      </div>
    </section>

    <div class="filter-strip" data-filter-bar>
      <button type="button" class="active" data-filter="all">All · {scored.length}</button>
      {groups.map((group) => (
        <button type="button" data-filter={group.slug}>
          {group.label}
          <span>{group.scoreText}</span>
          <i style={`background: ${group.status.color}`} />
        </button>
      ))}
    </div>

    {indicators.length === 0 ? (
      <section class="empty-state">
        <h2>No indicator data yet.</h2>
        <p>Run <code>ingest-backfill</code> to populate indicators.</p>
      </section>
    ) : (
      <section class="indicator-groups">
        {groups.map((group) => (
          <div class="indicator-group" data-subscore-section={group.slug}>
            <div class="group-header">
              <div>
                <h2>{group.label}</h2>
                <p>{group.description}</p>
              </div>
              <div class="group-score">
                <span>Weight {(group.weight * 100).toFixed(0)}%</span>
                <strong>{group.scoreText}</strong>
                <em style={`color: ${group.status.color}`}>{group.status.label}</em>
              </div>
            </div>

            <div class="indicator-grid">
              {group.cards.map((card) => (
                <button
                  type="button"
                  class="indicator-card"
                  data-indicator={JSON.stringify(card)}
                  style={`--status: ${card.status.color}`}
                >
                  <div class="card-top">
                    <div>
                      <span class="series-code">{card.code}</span>
                      <h3>{card.label}</h3>
                    </div>
                    <div class="card-score">
                      <span>Score</span>
                      <strong>{card.scoreText}</strong>
                    </div>
                  </div>

                  <div class="card-value-row">
                    <strong>{card.valueText}</strong>
                    {card.unit && <span>{card.unit}</span>}
                    <em class={card.deltaGood === false ? 'delta-bad' : card.deltaGood === true ? 'delta-good' : ''}>
                      {card.deltaText}
                      <small>{card.deltaLabel}</small>
                    </em>
                  </div>

                  {card.spark ? (
                    <div class="card-spark">
                      <svg viewBox="0 0 220 56" role="img" aria-label={`${card.label} recent history`}>
                        <defs>
                          <linearGradient id={`spark-${card.slug}`} x1="0" x2="0" y1="0" y2="1">
                            <stop offset="0%" stop-color={card.status.color} stop-opacity="0.20" />
                            <stop offset="100%" stop-color={card.status.color} stop-opacity="0" />
                          </linearGradient>
                        </defs>
                        <path d={card.spark.area} fill={`url(#spark-${card.slug})`} />
                        <path d={card.spark.d} fill="none" stroke={card.status.color} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                        <circle cx={card.spark.last[0]} cy={card.spark.last[1]} r="3" fill="#ffffff" stroke={card.status.color} stroke-width="1.6" />
                      </svg>
                    </div>
                  ) : (
                    <div class="card-spark card-spark-empty">History pending</div>
                  )}

                  <div class="card-foot">
                    <span>
                      <i></i>
                      {card.status.label}
                    </span>
                    <span>{card.frequency}</span>
                  </div>
                </button>
              ))}
            </div>
          </div>
        ))}
      </section>
    )}

    <div class="indicator-drawer" data-drawer hidden>
      <button type="button" class="drawer-backdrop" data-drawer-close aria-label="Close indicator drawer"></button>
      <aside class="drawer-panel" role="dialog" aria-modal="true" aria-labelledby="drawer-title">
        <button type="button" class="drawer-close" data-drawer-close aria-label="Close">×</button>
        <div class="drawer-meta" data-drawer-meta></div>
        <h2 id="drawer-title" data-drawer-title></h2>
        <div class="drawer-stats">
          <div>
            <span>Latest</span>
            <strong data-drawer-value></strong>
            <em data-drawer-unit></em>
          </div>
          <div>
            <span>Change</span>
            <strong data-drawer-delta></strong>
            <em data-drawer-delta-label></em>
          </div>
          <div>
            <span>Score</span>
            <strong data-drawer-score></strong>
            <em data-drawer-status></em>
          </div>
        </div>
        <div class="drawer-chart-wrap">
          <div class="drawer-chart-head">
            <span>Trailing history</span>
            <span data-drawer-range></span>
          </div>
          <div class="drawer-chart" data-drawer-chart></div>
        </div>
        <div class="drawer-method">
          <span>Methodology</span>
          <p data-drawer-description></p>
          <div>
            <span data-drawer-source></span>
            <span data-drawer-frequency></span>
            <span data-drawer-updated></span>
          </div>
          <a data-drawer-source-link href="#" target="_blank" rel="noopener" hidden>Open source data</a>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>

<style>
  .indicators-page {
    --bg: #fafaf7;
    --card: #ffffff;
    --ink: #0e1116;
    --ink-2: #2a2f38;
    --muted: #7a8290;
    --hairline: #e6e3da;
    --accent: #1f3df5;
    background: var(--bg);
    color: var(--ink);
    min-height: 100vh;
  }

  .indicators-hero {
    max-width: 1280px;
    margin: 0 auto;
    padding: 56px 56px 48px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(420px, 0.95fr);
    gap: 48px;
    align-items: end;
  }

  .hero-copy h1 {
    max-width: 660px;
    margin: 0;
    font-size: 72px;
    line-height: 0.98;
    font-weight: 500;
  }

  .hero-copy p {
    max-width: 540px;
    margin: 28px 0 0;
    color: var(--ink-2);
    font-size: 18px;
    line-height: 1.55;
  }

  .hero-updated {
    margin-top: 22px;
    color: var(--muted);
    font-family: "JetBrains Mono", Consolas, monospace;
    font-size: 11px;
    text-transform: uppercase;
  }

  .composite-card {
    background: var(--card);
    border: 1px solid var(--hairline);
    padding: 32px;
  }

  .composite-top {
    display: flex;
    justify-content: space-between;
    gap: 28px;
  }

  .eyebrow,
  .history-head,
  .series-code,
  .card-score span,
  .group-score span,
  .drawer-meta,
  .drawer-stats span,
  .drawer-chart-head,
  .drawer-method > span {
    color: var(--muted);
    font-family: "JetBrains Mono", Consolas, monospace;
    font-size: 10.5px;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .composite-score {
    margin-top: 12px;
    font-size: 92px;
    line-height: 0.9;
    font-weight: 500;
    font-variant-numeric: tabular-nums;
  }

  .status-line,
  .card-foot span:first-child {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    color: var(--status);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
  }

  .status-line span,
  .card-foot i {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: currentColor;
  }

  .composite-deltas {
    display: grid;
    gap: 18px;
    min-width: 88px;
  }

  .composite-deltas span,
  .subscore-mini strong,
  .card-value-row small,
  .card-foot span:last-child {
    display: block;
    color: var(--muted);
    font-family: "JetBrains Mono", Consolas, monospace;
    font-size: 10px;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .composite-deltas strong {
    display: block;
    color: #345544;
    font-size: 24px;
    font-weight: 500;
    font-variant-numeric: tabular-nums;
  }

  .delta-bad {
    color: #a04a2a !important;
  }

  .delta-good {
    color: #345544 !important;
  }

  .composite-history {
    margin-top: 28px;
  }

  .history-head,
  .drawer-chart-head {
    display: flex;
    justify-content: space-between;
    margin-bottom: 12px;
  }

  .composite-history svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .composite-history text {
    fill: var(--muted);
    font-family: "JetBrains Mono", Consolas, monospace;
    font-size: 9px;
  }

  .composite-empty {
    margin-top: 28px;
    color: var(--muted);
    border-top: 1px solid var(--hairline);
    padding-top: 20px;
    font-size: 14px;
  }

  .subscore-mini {
    margin-top: 26px;
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 6px;
  }

  .subscore-mini button {
    appearance: none;
    border: 0;
    background: transparent;
    padding: 0;
    color: inherit;
    cursor: pointer;
    font: inherit;
    text-align: left;
    text-decoration: none;
    min-width: 0;
  }

  .mini-bar-track {
    display: flex;
    align-items: flex-end;
    height: 54px;
    border: 1px solid var(--hairline);
    background: #fbfaf7;
    padding: 4px;
  }

  .mini-bar {
    display: block;
    width: 100%;
    min-height: 6px;
  }

  .mini-label {
    display: block;
    margin-top: 6px;
    color: var(--muted);
    font-family: "JetBrains Mono", Consolas, monospace;
    font-size: 9px;
    line-height: 1.1;
    text-transform: uppercase;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .filter-strip {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 56px 28px;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    border-bottom: 1px solid var(--hairline);
  }

  .filter-strip button {
    border: 1px solid var(--hairline);
    background: transparent;
    color: var(--ink);
    padding: 8px 16px;
    font: inherit;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .filter-strip button.active {
    background: var(--ink);
    border-color: var(--ink);
    color: var(--card);
  }

  .filter-strip span {
    color: var(--muted);
    font-family: "JetBrains Mono", Consolas, monospace;
    font-size: 11px;
    font-weight: 400;
  }

  .filter-strip button.active span {
    color: rgba(255, 255, 255, 0.7);
  }

  .filter-strip i {
    width: 5px;
    height: 5px;
    border-radius: 50%;
  }

  .indicator-groups {
    max-width: 1280px;
    margin: 0 auto;
    padding: 40px 56px 80px;
  }

  .indicator-group {
    margin-bottom: 56px;
  }

  .indicator-group[hidden] {
    display: none;
  }

  .group-header {
    padding: 14px 0 18px;
    display: flex;
    align-items: flex-end;
    gap: 28px;
    border-bottom: 1px solid var(--hairline);
    margin-bottom: 22px;
  }

  .group-header > div:first-child {
    flex: 1;
    min-width: 0;
  }

  .group-header h2 {
    margin: 0;
    font-size: 30px;
    line-height: 1.1;
    font-weight: 500;
  }

  .group-header p {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.5;
  }

  .group-score {
    text-align: right;
    flex: 0 0 auto;
  }

  .group-score strong {
    display: inline-block;
    margin-top: 6px;
    color: var(--ink);
    font-size: 46px;
    line-height: 1;
    font-weight: 500;
    font-variant-numeric: tabular-nums;
  }

  .group-score em {
    margin-left: 12px;
    font-style: normal;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
  }

  .indicator-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 18px;
  }

  .indicator-card {
    appearance: none;
    text-align: left;
    background: var(--card);
    border: 1px solid var(--hairline);
    padding: 22px;
    color: var(--ink);
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 14px;
    min-height: 276px;
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
  }

  .indicator-card:hover,
  .indicator-card:focus-visible {
    border-color: var(--ink);
    box-shadow: 0 8px 28px rgba(14, 17, 22, 0.08);
    outline: none;
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
  }

  .card-top h3 {
    margin: 6px 0 0;
    color: var(--ink);
    font-size: 15px;
    line-height: 1.25;
    font-weight: 600;
  }

  .card-score {
    text-align: right;
    flex: 0 0 auto;
  }

  .card-score strong {
    display: block;
    margin-top: 4px;
    font-size: 22px;
    line-height: 1;
    font-weight: 500;
    font-variant-numeric: tabular-nums;
  }

  .card-value-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }

  .card-value-row strong {
    color: var(--ink);
    font-size: 36px;
    line-height: 1;
    font-weight: 500;
    font-variant-numeric: tabular-nums;
  }

  .card-value-row > span {
    color: var(--muted);
    font-size: 12px;
  }

  .card-value-row em {
    margin-left: auto;
    color: var(--muted);
    font-family: "JetBrains Mono", Consolas, monospace;
    font-style: normal;
    font-size: 12px;
    font-variant-numeric: tabular-nums;
  }

  .card-spark {
    min-height: 66px;
  }

  .card-spark svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .card-spark-empty {
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
    display: flex;
    align-items: center;
    color: var(--muted);
    font-family: "JetBrains Mono", Consolas, monospace;
    font-size: 10px;
    text-transform: uppercase;
  }

  .card-foot {
    margin-top: auto;
    padding-top: 12px;
    border-top: 1px solid var(--hairline);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
  }

  .empty-state {
    max-width: 1280px;
    margin: 40px auto 0;
    padding: 48px 56px;
    color: var(--muted);
  }

  .empty-state h2 {
    color: var(--ink);
    margin: 0 0 8px;
    font-size: 24px;
    font-weight: 500;
  }

  .empty-state code {
    background: #ece8dd;
    color: var(--ink);
    padding: 2px 6px;
  }

  .indicator-drawer[hidden] {
    display: none;
  }

  .indicator-drawer {
    position: fixed;
    inset: 0;
    z-index: 80;
    display: flex;
    justify-content: flex-end;
  }

  .drawer-backdrop {
    position: absolute;
    inset: 0;
    border: 0;
    background: rgba(14, 17, 22, 0.42);
    cursor: pointer;
  }

  .drawer-panel {
    position: relative;
    width: min(720px, 94vw);
    height: 100%;
    overflow: auto;
    background: var(--card);
    box-shadow: -30px 0 60px rgba(0, 0, 0, 0.18);
    padding: 40px 48px 32px;
  }

  .drawer-close {
    position: absolute;
    top: 32px;
    right: 32px;
    width: 36px;
    height: 36px;
    border: 1px solid var(--hairline);
    border-radius: 999px;
    background: transparent;
    color: var(--ink);
    cursor: pointer;
    font-size: 18px;
  }

  .drawer-panel h2 {
    max-width: 560px;
    margin: 10px 0 0;
    color: var(--ink);
    font-size: 32px;
    line-height: 1.12;
    font-weight: 500;
  }

  .drawer-stats {
    margin-top: 32px;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 26px;
  }

  .drawer-stats strong {
    display: block;
    margin-top: 8px;
    color: var(--ink);
    font-size: 38px;
    line-height: 1;
    font-weight: 500;
    font-variant-numeric: tabular-nums;
  }

  .drawer-stats em {
    display: block;
    margin-top: 5px;
    color: var(--muted);
    font-size: 11px;
    font-style: normal;
  }

  .drawer-chart-wrap {
    margin-top: 32px;
    background: var(--bg);
    border: 1px solid var(--hairline);
    padding: 22px;
  }

  .drawer-chart svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .drawer-chart text {
    fill: var(--muted);
    font-family: "JetBrains Mono", Consolas, monospace;
    font-size: 10px;
  }

  .drawer-method {
    margin-top: 32px;
  }

  .drawer-method p {
    margin: 10px 0 0;
    color: var(--ink-2);
    font-size: 16px;
    line-height: 1.6;
  }

  .drawer-method div {
    margin-top: 18px;
    display: flex;
    flex-wrap: wrap;
    gap: 22px;
    color: var(--muted);
    font-family: "JetBrains Mono", Consolas, monospace;
    font-size: 11px;
    text-transform: uppercase;
  }

  .drawer-method a {
    display: inline-block;
    margin-top: 22px;
    color: var(--accent);
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
  }

  @media (max-width: 1100px) {
    .indicators-hero {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .hero-copy h1 {
      font-size: 56px;
      max-width: 760px;
    }

    .indicator-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 820px) {
    .indicators-hero,
    .filter-strip,
    .indicator-groups,
    .empty-state {
      padding-left: 24px;
      padding-right: 24px;
    }

    .hero-copy h1 {
      font-size: 44px;
      line-height: 1.02;
    }

    .hero-copy p {
      font-size: 16px;
    }

    .composite-card {
      padding: 22px;
    }

    .composite-score {
      font-size: 74px;
    }

    .subscore-mini {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .group-header {
      display: block;
    }

    .group-score {
      text-align: left;
      margin-top: 18px;
    }

    .indicator-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .drawer-panel {
      padding: 32px 24px;
    }

    .drawer-stats {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .indicator-grid,
    .subscore-mini {
      grid-template-columns: 1fr;
    }

    .composite-top {
      display: block;
    }

    .composite-deltas {
      margin-top: 24px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .indicator-card {
      min-height: 0;
    }
  }
</style>

<script>
  const drawer = document.querySelector('[data-drawer]');
  const closeButtons = document.querySelectorAll('[data-drawer-close]');
  const filterButtons = document.querySelectorAll('[data-filter]');
  const sections = document.querySelectorAll('[data-subscore-section]');

  function makePath(values, width = 600, height = 220, pad = 28) {
    if (!values || values.length < 2) return null;
    const min = Math.min(...values);
    const max = Math.max(...values);
    const spread = max - min || 1;
    const lo = min - spread * 0.08;
    const hi = max + spread * 0.08;
    const innerW = width - pad * 2;
    const innerH = height - pad * 2;
    const points = values.map((value, index) => {
      const x = pad + (index / (values.length - 1)) * innerW;
      const y = pad + (1 - (value - lo) / (hi - lo)) * innerH;
      return [x, y];
    });
    const d = points
      .map(([x, y], index) => `${index === 0 ? 'M' : 'L'}${x.toFixed(1)} ${y.toFixed(1)}`)
      .join(' ');
    const area = `${d} L${width - pad} ${height - pad} L${pad} ${height - pad} Z`;
    return { d, area, points, min, max, lo, hi };
  }

  function fmtNumber(n) {
    if (n == null || !Number.isFinite(Number(n))) return '-';
    return Number(n).toLocaleString('en-US', { maximumFractionDigits: 2 });
  }

  function setText(selector, value) {
    const el = drawer?.querySelector(selector);
    if (el) el.textContent = value ?? '';
  }

  function drawDrawerChart(card) {
    const wrap = drawer?.querySelector('[data-drawer-chart]');
    const range = drawer?.querySelector('[data-drawer-range]');
    const data = card.sparkline?.length > 1 ? card.sparkline : card.scoreSparkline;
    const path = makePath(data || []);
    if (!wrap || !range) return;
    if (!path) {
      range.textContent = 'History pending';
      wrap.innerHTML = '<div style="height:220px;display:flex;align-items:center;color:#7a8290;">History pending</div>';
      return;
    }
    const color = card.status.color;
    range.textContent = `min ${fmtNumber(path.min)} · max ${fmtNumber(path.max)}`;
    const yTicks = [0, 0.25, 0.5, 0.75, 1].map((f) => path.lo + (path.hi - path.lo) * f);
    const grid = yTicks.map((value) => {
      const y = 28 + (1 - (value - path.lo) / (path.hi - path.lo)) * (220 - 56);
      return `<g><line x1="44" x2="582" y1="${y}" y2="${y}" stroke="#e6e3da"/><text x="36" y="${y + 3}" text-anchor="end">${fmtNumber(value)}</text></g>`;
    }).join('');
    const last = path.points[path.points.length - 1];
    wrap.innerHTML = `
      <svg viewBox="0 0 600 220" role="img" aria-label="${card.label} trailing history">
        <defs>
          <linearGradient id="drawer-gradient" x1="0" x2="0" y1="0" y2="1">
            <stop offset="0%" stop-color="${color}" stop-opacity="0.22" />
            <stop offset="100%" stop-color="${color}" stop-opacity="0" />
          </linearGradient>
        </defs>
        ${grid}
        <path d="${path.area}" fill="url(#drawer-gradient)" />
        <path d="${path.d}" fill="none" stroke="${color}" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
        <line x1="${last[0]}" x2="582" y1="${last[1]}" y2="${last[1]}" stroke="${color}" stroke-dasharray="2 3" />
        <circle cx="${last[0]}" cy="${last[1]}" r="4" fill="#fff" stroke="${color}" stroke-width="2" />
      </svg>
    `;
  }

  function openDrawer(card) {
    if (!drawer) return;
    drawer.hidden = false;
    document.body.style.overflow = 'hidden';
    setText('[data-drawer-meta]', `${card.subscoreLabel.toUpperCase()} · ${card.code}`);
    setText('[data-drawer-title]', card.label);
    setText('[data-drawer-value]', card.valueText);
    setText('[data-drawer-unit]', card.unitLong || card.unit);
    setText('[data-drawer-delta]', card.deltaText);
    setText('[data-drawer-delta-label]', card.deltaLabel);
    setText('[data-drawer-score]', card.scoreText);
    setText('[data-drawer-status]', card.status.label);
    setText('[data-drawer-description]', card.description || 'No methodology note is available for this indicator yet.');
    setText('[data-drawer-source]', `Source · ${card.sourceName}`);
    setText('[data-drawer-frequency]', `Frequency · ${card.frequency}`);
    setText('[data-drawer-updated]', `Updated · ${card.latestDate}`);
    const sourceLink = drawer.querySelector('[data-drawer-source-link]');
    if (sourceLink) {
      if (card.sourceUrl) {
        sourceLink.setAttribute('href', card.sourceUrl);
        sourceLink.removeAttribute('hidden');
      } else {
        sourceLink.setAttribute('hidden', '');
      }
    }
    const scoreEl = drawer.querySelector('[data-drawer-score]');
    const statusEl = drawer.querySelector('[data-drawer-status]');
    if (scoreEl) scoreEl.style.color = card.status.color;
    if (statusEl) statusEl.style.color = card.status.color;
    drawDrawerChart(card);
  }

  function closeDrawer() {
    if (!drawer) return;
    drawer.hidden = true;
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.indicator-card').forEach((button) => {
    button.addEventListener('click', () => {
      const raw = button.getAttribute('data-indicator');
      if (!raw) return;
      openDrawer(JSON.parse(raw));
    });
  });

  closeButtons.forEach((button) => button.addEventListener('click', closeDrawer));
  window.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeDrawer();
  });

  filterButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const filter = button.getAttribute('data-filter');
      filterButtons.forEach((candidate) => {
        candidate.classList.toggle('active', candidate.getAttribute('data-filter') === filter);
      });
      sections.forEach((section) => {
        section.toggleAttribute('hidden', filter !== 'all' && section.getAttribute('data-subscore-section') !== filter);
      });
    });
  });
</script>
