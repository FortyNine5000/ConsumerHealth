---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeadlineScore from '../components/HeadlineScore.astro';
import SubScoreCard from '../components/SubScoreCard.astro';
import DataVsNarrative from '../components/DataVsNarrative.astro';
import QuoteCard from '../components/QuoteCard.astro';
import {
  getLatestHeadlineScore,
  getLatestSubScores,
  getRecentQuotes,
} from '../lib/db';
import { formatDate } from '../lib/scoring';

let headline = null;
let subscores = [];
let quotes = [];

try {
  [headline, subscores, quotes] = await Promise.all([
    getLatestHeadlineScore(),
    getLatestSubScores(),
    getRecentQuotes(12),
  ]);
} catch (e) {
  // DB not yet populated — show placeholder UI
}

const hasData = headline !== null;
const movers: { gains: string[]; drops: string[] } = { gains: [], drops: [] };
if (headline?.biggest_gains) {
  try { movers.gains = JSON.parse(headline.biggest_gains); } catch {}
}
if (headline?.biggest_drops) {
  try { movers.drops = JSON.parse(headline.biggest_drops); } catch {}
}
---

<BaseLayout title="The Consumer Compass">
  <!-- Hero section -->
  <section class="bg-compass-navy text-white py-10 px-4 sm:px-6 lg:px-8">
    <div class="max-w-6xl mx-auto">
      <div class="mb-6">
        <h1 class="text-2xl sm:text-3xl font-bold tracking-tight mb-2">
          U.S. Consumer Financial Health
        </h1>
        <p class="text-gray-300 text-sm sm:text-base max-w-2xl">
          A composite 0–100 score built from 30 free government indicators across 7 dimensions of household financial health — updated automatically.
        </p>
      </div>

      {hasData ? (
        <HeadlineScore data={headline} />
      ) : (
        <div class="bg-white/10 rounded-2xl p-8 text-center">
          <div class="text-5xl font-bold text-gray-400 mb-2">—</div>
          <p class="text-gray-300">Awaiting first data ingestion run.</p>
          <p class="text-gray-400 text-sm mt-1">Run <code class="font-mono bg-white/10 px-1 rounded">ingest-backfill</code> to populate.</p>
        </div>
      )}
    </div>
  </section>

  <!-- Main content -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-10">

    <!-- Biggest movers -->
    {hasData && (movers.gains.length > 0 || movers.drops.length > 0) && (
      <section>
        <h2 class="text-lg font-semibold text-compass-navy mb-4">What Changed</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {movers.gains.length > 0 && (
            <div class="bg-green-50 border border-green-100 rounded-xl p-4">
              <div class="text-xs font-semibold text-green-700 uppercase tracking-wide mb-2">Biggest Gains</div>
              <ul class="space-y-1">
                {movers.gains.map((m: string) => (
                  <li class="text-sm text-green-800 flex items-center gap-2">
                    <span class="text-green-500">↑</span> {m}
                  </li>
                ))}
              </ul>
            </div>
          )}
          {movers.drops.length > 0 && (
            <div class="bg-red-50 border border-red-100 rounded-xl p-4">
              <div class="text-xs font-semibold text-red-700 uppercase tracking-wide mb-2">Biggest Drops</div>
              <ul class="space-y-1">
                {movers.drops.map((m: string) => (
                  <li class="text-sm text-red-800 flex items-center gap-2">
                    <span class="text-red-500">↓</span> {m}
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </section>
    )}

    <!-- Sub-scores grid -->
    <section>
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-compass-navy">7 Sub-Scores</h2>
        <a href="/indicators" class="text-sm text-compass-teal hover:underline">View all indicators →</a>
      </div>
      {subscores.length > 0 ? (
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
          {subscores.map((s) => <SubScoreCard data={s} />)}
        </div>
      ) : (
        <div class="bg-gray-100 rounded-xl p-8 text-center text-gray-400 text-sm">
          Sub-scores will appear after first ingestion run.
        </div>
      )}
    </section>

    <!-- Data vs Narrative + Recent Quotes -->
    <section class="grid grid-cols-1 lg:grid-cols-5 gap-6">
      <div class="lg:col-span-2">
        <DataVsNarrative subscores={subscores} quotes={quotes} />
      </div>
      <div class="lg:col-span-3">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-compass-navy">Recent Earnings Quotes</h2>
          <a href="/quotes" class="text-sm text-compass-teal hover:underline">All quotes →</a>
        </div>
        {quotes.length > 0 ? (
          <div class="space-y-3">
            {quotes.slice(0, 4).map((q) => <QuoteCard quote={q} compact={true} />)}
          </div>
        ) : (
          <div class="bg-gray-100 rounded-xl p-8 text-center text-gray-400 text-sm">
            Earnings quotes will appear after the SEC EDGAR ingestion pipeline runs.
          </div>
        )}
      </div>
    </section>

    <!-- Score band legend -->
    <section class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
      <h2 class="text-lg font-semibold text-compass-navy mb-4">Score Bands</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
        {[
          { range: '85–100', label: 'Very Strong', color: '#1a7c3e' },
          { range: '70–84',  label: 'Healthy',     color: '#2ecc71' },
          { range: '55–69',  label: 'Mixed',        color: '#f0c419' },
          { range: '40–54',  label: 'Weakening',    color: '#e67e22' },
          { range: '25–39',  label: 'Stressed',     color: '#e74c3c' },
          { range: '0–24',   label: 'Crisis',       color: '#8b0000' },
        ].map(({ range, label, color }) => (
          <div class="text-center p-3 rounded-lg" style={`background-color: ${color}15; border: 1px solid ${color}40`}>
            <div class="text-xs font-mono text-gray-500 mb-1">{range}</div>
            <div class="text-sm font-semibold" style={`color: ${color}`}>{label}</div>
          </div>
        ))}
      </div>
      <p class="mt-4 text-xs text-gray-400">
        Scores use expanding-window percentile ranking across all available history (back to 1990). Recessions naturally appear as drops into Stressed or Crisis territory.
        <a href="/methodology" class="text-compass-teal hover:underline ml-1">Full methodology →</a>
      </p>
    </section>
  </div>
</BaseLayout>
