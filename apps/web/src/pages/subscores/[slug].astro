---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SubScoreCard from '../../components/SubScoreCard.astro';
import { getAllIndicators, getLatestSubScores, getSubScoreHistory } from '../../lib/db';
import { scoreToBand, formatDate, SUBSCORE_LABELS, SUBSCORE_DESCRIPTIONS } from '../../lib/scoring';

const SUBSCORE_SLUGS = [
  'labor_income',
  'household_balance_sheet',
  'credit_stress',
  'spending_demand',
  'sentiment_expectations',
  'inflation_affordability',
  'big_ticket_affordability',
];

export async function getStaticPaths() {
  return SUBSCORE_SLUGS.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;

if (!SUBSCORE_SLUGS.includes(slug!)) {
  return Astro.redirect('/');
}

let history: { score_date: string; score: number }[] = [];
let indicators = [];
let subscores = [];

try {
  [history, indicators, subscores] = await Promise.all([
    getSubScoreHistory(slug!),
    getAllIndicators(),
    getLatestSubScores(),
  ]);
} catch (e) {}

const currentSubscore = subscores.find((s) => s.slug === slug);
const currentScore = currentSubscore?.score ?? null;
const band = currentScore != null ? scoreToBand(currentScore) : null;
const latestDate = currentSubscore?.score_date ?? null;
const label = SUBSCORE_LABELS[slug!] ?? slug;
const description = SUBSCORE_DESCRIPTIONS[slug!] ?? '';

const subIndicators = indicators.filter((i) => i.subscore === slug && i.is_scored === 1);

const chartData = JSON.stringify(history.map((h) => ({ date: h.score_date.slice(0, 7), score: h.score })));
---

<BaseLayout
  title={`${label} Sub-Score`}
  description={`${label} sub-score — ${description}`}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-400 mb-6 flex items-center gap-2">
      <a href="/" class="hover:text-compass-teal transition-colors">Home</a>
      <span>›</span>
      <span class="text-gray-600">{label}</span>
    </nav>

    <!-- Header -->
    <div class="flex items-start justify-between gap-6 mb-8">
      <div>
        <h1 class="text-2xl sm:text-3xl font-bold text-compass-navy">{label}</h1>
        <p class="text-gray-500 mt-1 text-sm max-w-xl">{description}</p>
      </div>
      {band && currentScore != null && (
        <div class="text-right shrink-0">
          <div class="text-4xl font-bold tabular-nums" style={`color: ${band.color}`}>
            {currentScore.toFixed(0)}
          </div>
          <div class="text-sm font-medium mt-0.5" style={`color: ${band.color}`}>{band.label}</div>
          {latestDate && <div class="text-xs text-gray-400 mt-1">{formatDate(latestDate)}</div>}
        </div>
      )}
    </div>

    <!-- History chart -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 mb-8">
      <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-4">Sub-Score History</h2>
      {history.length > 0 ? (
        <div
          class="subscore-chart"
          data-chart={chartData}
          data-color={band?.color ?? '#0d9488'}
          style="height: 260px; width: 100%;"
        />
      ) : (
        <div class="h-40 flex items-center justify-center text-gray-400 text-sm">No history yet.</div>
      )}
    </div>

    <!-- Indicators breakdown -->
    <div class="mb-8">
      <h2 class="text-lg font-semibold text-compass-navy mb-4">Component Indicators</h2>
      {subIndicators.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {subIndicators.map((ind) => {
            const indBand = ind.latest_score != null ? scoreToBand(ind.latest_score) : null;
            return (
              <a
                href={`/indicators/${ind.slug}`}
                class="bg-white rounded-xl border border-gray-100 p-4 shadow-sm hover:shadow-md transition-all"
              >
                <div class="flex items-start justify-between">
                  <div>
                    <div class="font-medium text-sm text-gray-800">{ind.label}</div>
                    <div class="text-xs text-gray-400 mt-0.5 font-mono">{ind.series_id}</div>
                  </div>
                  <div
                    class="text-xl font-bold tabular-nums"
                    style={indBand ? `color: ${indBand.color}` : 'color: #94a3b8'}
                  >
                    {ind.latest_score != null ? ind.latest_score.toFixed(0) : '—'}
                  </div>
                </div>
                <div class="mt-2 flex items-center gap-2">
                  <span class="text-xs px-2 py-0.5 bg-gray-100 text-gray-500 rounded-full">{ind.frequency}</span>
                  <span class="text-xs text-gray-400 ml-auto">
                    weight: {(ind.weight_in_subscore * 100).toFixed(0)}%
                  </span>
                </div>
              </a>
            );
          })}
        </div>
      ) : (
        <div class="bg-gray-100 rounded-xl p-8 text-center text-gray-400 text-sm">
          No indicator data yet.
        </div>
      )}
    </div>
  </div>
</BaseLayout>

<script>
  import * as echarts from 'echarts';
  import { buildRecessionMarkAreas } from '../../lib/echarts';

  document.querySelectorAll<HTMLElement>('.subscore-chart').forEach((el) => {
    const raw = JSON.parse(el.dataset.chart ?? '[]') as { date: string; score: number }[];
    const color = el.dataset.color ?? '#0d9488';

    const chart = echarts.init(el, null, { renderer: 'svg' });
    chart.setOption({
      backgroundColor: 'transparent',
      grid: { top: 20, right: 16, bottom: 36, left: 48 },
      tooltip: {
        trigger: 'axis',
        formatter: (p: any) => {
          const a = Array.isArray(p) ? p[0] : p;
          return `${a.axisValue}<br/>Score: <b>${a.value?.toFixed(1)}</b>`;
        },
      },
      xAxis: {
        type: 'category',
        data: raw.map((d) => d.date),
        axisLabel: { fontSize: 11, color: '#94a3b8' },
        axisLine: { lineStyle: { color: '#e5e7eb' } },
        splitLine: { show: false },
      },
      yAxis: {
        type: 'value', min: 0, max: 100,
        axisLabel: { color: '#94a3b8', fontSize: 11 },
        splitLine: { lineStyle: { color: '#f1f5f9' } },
      },
      series: [{
        type: 'line',
        data: raw.map((d) => d.score),
        smooth: true,
        symbol: 'none',
        lineStyle: { color, width: 2 },
        areaStyle: { color, opacity: 0.1 },
        markArea: { silent: true, data: buildRecessionMarkAreas() },
      }],
    });
    window.addEventListener('resize', () => chart.resize());
  });
</script>
