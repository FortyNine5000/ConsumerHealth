---
import type { HeadlineScore } from '../lib/db';
import { formatScore, formatDelta, deltaColor, formatDate } from '../lib/scoring';

interface Props {
  data: HeadlineScore | null;
}

const { data } = Astro.props;

const score = data?.score ?? null;
const band = data?.band ?? 'No Data';
const bandColor = data?.band_color ?? '#94a3b8';
const delta1m = data?.delta_1m ?? null;
const delta3m = data?.delta_3m ?? null;
const delta12m = data?.delta_12m ?? null;
const oneLiner = data?.one_liner ?? null;
const scoreDate = data?.score_date ? formatDate(data.score_date) : null;

// Gauge arc: score 0–100 maps to -140° to +140° (280° sweep)
const gaugeAngle = score !== null ? -140 + (score / 100) * 280 : -140;
const cx = 120;
const cy = 110;
const r = 90;

function polarToXY(angleDeg: number, radius: number) {
  const rad = (angleDeg - 90) * (Math.PI / 180);
  return { x: cx + radius * Math.cos(rad), y: cy + radius * Math.sin(rad) };
}

const needleTip = polarToXY(gaugeAngle, r - 8);
const needleBase1 = polarToXY(gaugeAngle + 90, 8);
const needleBase2 = polarToXY(gaugeAngle - 90, 8);
---

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 lg:p-8">
  <div class="flex flex-col lg:flex-row items-center gap-8">
    <!-- Gauge SVG -->
    <div class="flex-shrink-0">
      <svg width="240" height="190" viewBox="0 0 240 190" aria-label={`Consumer health score: ${score}`}>
        <!-- Track bg (drawn first so colored bands render on top) -->
        {(() => {
          const p1 = polarToXY(-140, r);
          const p2 = polarToXY(140, r);
          return (
            <path
              d={`M ${p1.x} ${p1.y} A ${r} ${r} 0 1 1 ${p2.x} ${p2.y}`}
              fill="none"
              stroke="#e5e7eb"
              stroke-width="16"
              stroke-linecap="butt"
            />
          );
        })()}

        <!-- Band arc segments -->
        {[
          { start: -140, end: -84, color: '#8b0000' },
          { start: -84,  end: -28, color: '#e74c3c' },
          { start: -28,  end: 28,  color: '#e67e22' },
          { start: 28,   end: 84,  color: '#f0c419' },
          { start: 84,   end: 112, color: '#2ecc71' },
          { start: 112,  end: 140, color: '#1a7c3e' },
        ].map(({ start, end, color }) => {
          const p1 = polarToXY(start, r);
          const p2 = polarToXY(end, r);
          const large = end - start > 180 ? 1 : 0;
          return (
            <path
              d={`M ${p1.x} ${p1.y} A ${r} ${r} 0 ${large} 1 ${p2.x} ${p2.y}`}
              fill="none"
              stroke={color}
              stroke-width="14"
              stroke-linecap="butt"
            />
          );
        })}

        <!-- Needle -->
        {score !== null && (
          <polygon
            points={`${needleTip.x},${needleTip.y} ${needleBase1.x},${needleBase1.y} ${needleBase2.x},${needleBase2.y}`}
            fill={bandColor}
          />
        )}

        <!-- Center score text -->
        <text x={cx} y={cy + 20} text-anchor="middle" font-family="Inter,system-ui,sans-serif">
          <tspan font-size="36" font-weight="700" fill={bandColor}>{score !== null ? score.toFixed(0) : '—'}</tspan>
          <tspan font-size="14" fill="#94a3b8" dy="4"> /100</tspan>
        </text>
      </svg>
    </div>

    <!-- Score details -->
    <div class="flex-1 min-w-0">
      <div class="flex items-baseline gap-3 flex-wrap">
        <span
          class="text-3xl font-bold tracking-tight"
          style={`color: ${bandColor}`}
        >{band}</span>
        {scoreDate && (
          <span class="text-sm text-gray-400">as of {scoreDate}</span>
        )}
      </div>

      {oneLiner && (
        <p class="mt-2 text-gray-600 leading-relaxed text-sm lg:text-base max-w-lg">{oneLiner}</p>
      )}

      <!-- Deltas -->
      <div class="mt-4 flex gap-6 text-sm">
        <div>
          <div class="text-gray-400 text-xs uppercase tracking-wide mb-1">1 month</div>
          <div class={`font-semibold ${deltaColor(delta1m)}`}>{formatDelta(delta1m)}</div>
        </div>
        <div>
          <div class="text-gray-400 text-xs uppercase tracking-wide mb-1">3 months</div>
          <div class={`font-semibold ${deltaColor(delta3m)}`}>{formatDelta(delta3m)}</div>
        </div>
        <div>
          <div class="text-gray-400 text-xs uppercase tracking-wide mb-1">12 months</div>
          <div class={`font-semibold ${deltaColor(delta12m)}`}>{formatDelta(delta12m)}</div>
        </div>
      </div>
    </div>
  </div>
</div>
